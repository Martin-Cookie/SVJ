DEBUG=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vas-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # App Password z Google účtu
SMTP_FROM_NAME=SVJ
SMTP_FROM_EMAIL=vas-email@gmail.com
SMTP_USE_TLS=true

# IMAP — kontrola nedoručených (bounce) emailů
# Pokud necháte IMAP_USER/IMAP_PASSWORD prázdné, použijí se SMTP přihlašovací údaje
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true

LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
